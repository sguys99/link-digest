# ============================================
# Supabase (필수)
# 대시보드 > Project Settings > API
# NEXT_PUBLIC_* 은 클라이언트에 노출됨 (anon key 전용)
# SERVICE_ROLE_KEY 는 절대 NEXT_PUBLIC_ 접두사를 붙이지 말 것 — 서버 전용
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# LLM API (최소 1개 provider 필요 — 서버 전용)
# 사용자가 Settings 페이지에서 본인 키를 입력하면 DB 값이 우선 사용됨
# 아래 환경변수는 사용자 설정이 없을 때의 fallback 용도
# *_MODEL 은 선택 — 미지정 시 코드의 DEFAULT_MODELS 사용
# ============================================
# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini
# 신규 사용자에게 무료 AI 요약을 기본 제공하려면 배포 환경(Vercel 등)에
# 이 키만 설정해두세요. 사용자 본인 키 없이도 gemini-2.0-flash 로 요약이 동작합니다.
# 이 경우 무료 사용자 한도(DAILY_LINK_LIMIT_FREE)가 자동 적용됩니다.
GOOGLE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ============================================
# Resend (이메일 발송 — 뉴스레터 기능 사용 시 필수, 서버 전용)
# https://resend.com/api-keys 에서 발급
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================
# Vercel Cron (뉴스레터 cron 엔드포인트 Bearer 인증, 서버 전용)
# Vercel 배포 시 임의의 긴 랜덤 문자열로 설정
# ============================================
CRON_SECRET=

# ============================================
# App URL (배포 환경 기준 절대 URL, 클라이언트 노출 가능)
# 현재 OAuth redirect 는 window.location.origin 기반이라 코드에선 미사용이나,
# 이메일/외부 채널에 절대 링크를 포함할 경우 대비해 프로덕션 도메인으로 설정 권장
# 로컬: http://localhost:3000
# 프로덕션: https://your-domain.vercel.app
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Admin (공지사항 생성/편집 권한 판정용 이메일, 서버 전용)
# 이 이메일로 로그인한 사용자만 /announcements 에서 관리 액션 노출
# ============================================
ADMIN_EMAIL=sguys99@gmail.com

# ============================================
# 참고: 환경변수가 아닌 항목
# - Slack webhook URL, Telegram bot token/chat ID 는 사용자별로
#   Settings 페이지에서 입력되어 Supabase users.notification_settings JSONB 에 저장됩니다.
#   이 파일에 추가하지 마세요.
# ============================================
