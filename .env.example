# ============================================
# Supabase (필수)
# Supabase 대시보드 > Project Settings > API에서 확인
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 사이드 전용 — 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# LLM API (최소 1개 provider 키 필요)
# Settings 페이지에서 사용자별로 provider 선택 가능
# ============================================
# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini
GOOGLE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ============================================
# Resend (이메일 발송 — 뉴스레터 기능 사용 시 필수)
# https://resend.com/api-keys 에서 발급
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================
# Vercel Cron (뉴스레터 cron 엔드포인트 인증)
# Vercel 배포 시 자동 생성되거나 직접 설정
# ============================================
CRON_SECRET=

# ============================================
# App URL (배포 환경에 맞게 변경)
# 로컬: http://localhost:3000
# 프로덕션: https://your-domain.vercel.app
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Admin (공지사항 관리 등 관리자 기능)
# ============================================
ADMIN_EMAIL=sguys99@gmail.com
